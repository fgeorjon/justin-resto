# Copie ce fichier en .env  (le .env n'est jamais commite — cf .gitignore)
# Ces variables ne servent QU'au script de rebranchement VeraTrace (papa).
# Le site Astro lui-meme n'a besoin d'aucune variable.

# URL de la plateforme VeraTrace
VERATRACE_BASE_URL=https://veratrace.xyz

# Cookie de session d'un compte VeraTrace connecte (voir README § Rebrancher).
# Ne le partage jamais, ne le commite jamais.
VERATRACE_COOKIE=

# (optionnel) force le slug du micro-site ; sinon derive du nom du resto.
MICROSITE_SLUG=
