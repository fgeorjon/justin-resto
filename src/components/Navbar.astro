---
import Logo from './Logo.astro';
import { navLinks, restaurant } from '../data/restaurant';

const currentPath = Astro.url.pathname;
---

<header id="site-nav" class="fixed inset-x-0 top-0 z-50 transition-all duration-300" data-state="top">
  <nav class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-5 py-4 sm:px-8">
    <Logo />

    <ul class="hidden items-center gap-8 rounded-full px-2 font-body text-sm font-medium text-cream-100/90 lg:flex">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              'relative py-1 transition-colors duration-200 hover:text-cheese-300',
              currentPath === link.href && 'text-cheese-300',
            ]}
          >
            {link.label}
            {currentPath === link.href && (
              <span class="absolute -bottom-1 left-0 h-[2px] w-full bg-cheese-400"></span>
            )}
          </a>
        </li>
      ))}
    </ul>

    <div class="hidden items-center gap-3 lg:flex">
      <a
        href={restaurant.phoneHref}
        class="rounded-full border border-cream-100/20 px-5 py-2.5 text-sm font-semibold text-cream-50 transition-colors duration-200 hover:border-cheese-400 hover:text-cheese-300"
      >
        Commander
      </a>
      <a
        href="/menu"
        class="rounded-full bg-sauce-500 px-5 py-2.5 text-sm font-semibold text-cream-50 shadow-soft transition-transform duration-200 hover:-translate-y-0.5 hover:bg-sauce-400"
      >
        Voir le menu
      </a>
    </div>

    <button
      id="nav-burger"
      type="button"
      class="grid h-10 w-10 place-items-center rounded-full border border-cream-100/20 text-cream-50 lg:hidden"
      aria-label="Ouvrir le menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg id="icon-burger" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
      <svg id="icon-close" class="hidden h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
    </button>
  </nav>

  <div
    id="mobile-menu"
    class="hidden origin-top border-t border-cream-100/10 bg-crust-950/98 px-5 pb-6 pt-2 backdrop-blur lg:hidden"
  >
    <ul class="flex flex-col gap-1 font-body text-base">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              'block rounded-xl px-3 py-3 transition-colors',
              currentPath === link.href ? 'bg-cream-50/5 text-cheese-300' : 'text-cream-100/90 hover:bg-cream-50/5',
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
    <div class="mt-4 flex flex-col gap-3">
      <a href={restaurant.phoneHref} class="rounded-full border border-cream-100/20 px-5 py-3 text-center text-sm font-semibold text-cream-50">
        Appeler · {restaurant.phone}
      </a>
      <a href="/menu" class="rounded-full bg-sauce-500 px-5 py-3 text-center text-sm font-semibold text-cream-50 shadow-soft">
        Voir le menu
      </a>
    </div>
  </div>
</header>

<script>
  const nav = document.getElementById('site-nav');
  const burger = document.getElementById('nav-burger');
  const menu = document.getElementById('mobile-menu');
  const iconBurger = document.getElementById('icon-burger');
  const iconClose = document.getElementById('icon-close');

  const applyScrollState = () => {
    if (!nav) return;
    const scrolled = window.scrollY > 24;
    nav.dataset.state = scrolled ? 'scrolled' : 'top';
    nav.classList.toggle('bg-crust-950/90', scrolled);
    nav.classList.toggle('backdrop-blur-md', scrolled);
    nav.classList.toggle('shadow-[0_8px_30px_-12px_rgba(0,0,0,0.6)]', scrolled);
    nav.classList.toggle('border-b', scrolled);
    nav.classList.toggle('border-cream-100/10', scrolled);
  };
  applyScrollState();
  window.addEventListener('scroll', applyScrollState, { passive: true });

  burger?.addEventListener('click', () => {
    const isOpen = menu?.classList.contains('hidden') === false;
    menu?.classList.toggle('hidden');
    iconBurger?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
    burger.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
