---
import type { Pizza } from '../data/menu';

interface Props {
  pizza: Pizza;
  index?: number;
}
const { pizza, index = 0 } = Astro.props;

const fmt = (n: number) => `${n.toFixed(2).replace('.', ',')} €`;
---

<article
  class="reveal group relative flex flex-col justify-between overflow-hidden rounded-2xl border border-cream-100/10 bg-crust-900/50 p-6 transition-all duration-300 hover:-translate-y-1 hover:border-cheese-400/40 hover:bg-crust-900"
  style={`transition-delay:${(index % 6) * 60}ms`}
>
  {pizza.featured && (
    <span class="absolute right-5 top-5 rounded-full bg-cheese-400/15 px-2.5 py-1 font-body text-[0.65rem] font-semibold uppercase tracking-wider text-cheese-300">
      Coup de cœur
    </span>
  )}

  <div>
    <h3 class="pr-20 font-display text-xl font-semibold text-cream-50">{pizza.name}</h3>
    <p class="mt-2 font-body text-sm leading-relaxed text-cream-100/60">{pizza.description}</p>
  </div>

  <div class="mt-6 flex items-end justify-between border-t border-cream-100/10 pt-4">
    <span class="font-body text-[0.7rem] uppercase tracking-widest text-cream-100/40">Medium · Large</span>
    <span class="font-display text-base font-semibold text-cheese-300">
      {fmt(pizza.priceMedium)} <span class="text-cream-100/30">/</span> {fmt(pizza.priceLarge)}
    </span>
  </div>
</article>
