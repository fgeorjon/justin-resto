---
import { pizzaTiers, extraToppings } from '../data/menu';

const fmt = (n: number) => `${n.toFixed(2).replace('.', ',')} €`;
---

<div class="space-y-16">
  {pizzaTiers.map((tier, tIndex) => (
    <div>
      <h3 class="reveal font-display text-2xl font-bold text-cream-50">{tier.title}</h3>
      <div class="mt-3 h-px w-16 bg-cheese-400"></div>

      <div class="mt-7 grid gap-x-10 gap-y-1 lg:grid-cols-2">
        {tier.pizzas.map((pizza, i) => (
          <div
            class="reveal group flex items-baseline gap-3 border-b border-cream-100/8 py-4"
            style={`transition-delay:${((tIndex * 4 + i) % 6) * 50}ms`}
          >
            <div class="min-w-0">
              <div class="flex items-baseline gap-2">
                <span class="font-display text-base font-semibold text-cream-50">{pizza.name}</span>
                {pizza.featured && (
                  <span class="shrink-0 font-body text-[0.6rem] font-semibold uppercase tracking-wider text-cheese-400">★ Populaire</span>
                )}
              </div>
              <p class="mt-1 font-body text-[0.83rem] leading-snug text-cream-100/55">{pizza.description}</p>
            </div>
            <div class="ml-auto flex-1 border-b border-dotted border-cream-100/15 self-end mb-1.5"></div>
            <span class="shrink-0 self-start whitespace-nowrap font-body text-sm font-semibold text-cheese-300">
              {fmt(pizza.priceMedium)} / {fmt(pizza.priceLarge)}
            </span>
          </div>
        ))}
      </div>
    </div>
  ))}

  <div class="reveal rounded-2xl border border-cream-100/10 bg-crust-900/50 p-6 sm:p-8">
    <h3 class="font-display text-lg font-semibold text-cream-50">Ingrédient supplémentaire</h3>
    <p class="mt-1 font-body text-sm text-cheese-300">
      + {fmt(extraToppings.priceMedium)} medium · + {fmt(extraToppings.priceLarge)} large
    </p>
    <p class="mt-4 font-body text-sm leading-relaxed text-cream-100/55">
      {extraToppings.items.join(' · ')}
    </p>
  </div>
</div>
