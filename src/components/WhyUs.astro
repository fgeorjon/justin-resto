---
import SectionHeading from './SectionHeading.astro';

const reasons = [
  {
    title: 'Pâte au choix',
    description: "Classic, Fine ou Pan à l'américaine : trois textures pour une pizza à votre façon.",
    icon: 'M4 12a8 8 0 1 1 16 0 8 8 0 0 1-16 0Zm8-8v16',
  },
  {
    title: 'Pensé pour le groupe',
    description: 'Familles, étudiants, groupes d\'amis — des pizzas généreuses qui se partagent.',
    icon: 'M9 11a3 3 0 1 0 0-6 3 3 0 0 0 0 6Zm6 0a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM4 20c0-3 2.5-5 5-5s5 2 5 5M14 20c0-2.5 2-4.5 4.5-4.5s4.5 2 4.5 4.5',
  },
  {
    title: 'Rapide à emporter',
    description: 'Commande simple, préparation rapide — parfait pour un repas sur le pouce.',
    icon: 'M13 2 4 14h7l-1 8 9-12h-7l1-8Z',
  },
  {
    title: 'Options végétariennes',
    description: 'Une sélection pensée pour tous les régimes, sans compromis sur le goût.',
    icon: 'M12 22c5-1 8-5 8-11a8 8 0 0 0-8-8c-1 4-5 5-5 10a5 5 0 0 0 5 5Z',
  },
];
---

<section class="bg-crust-900/60 py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-5 sm:px-8">
    <SectionHeading
      eyebrow="L'expérience Molly's"
      title="Pourquoi nous choisir"
      description="Une pizzeria de quartier, pensée pour aller vite sans jamais sacrifier le goût."
    />

    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {reasons.map((reason, i) => (
        <div
          class="reveal group relative overflow-hidden rounded-2xl border border-cream-100/10 bg-crust-950/60 p-7 transition-colors duration-300 hover:border-cheese-400/40"
          style={`transition-delay:${i * 60}ms`}
        >
          <div class="grid h-12 w-12 place-items-center rounded-xl bg-sauce-500/15 text-sauce-400 transition-colors duration-300 group-hover:bg-cheese-400/15 group-hover:text-cheese-300">
            <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d={reason.icon} />
            </svg>
          </div>
          <h3 class="mt-5 font-display text-lg font-semibold text-cream-50">{reason.title}</h3>
          <p class="mt-2 font-body text-sm leading-relaxed text-cream-100/60">{reason.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
