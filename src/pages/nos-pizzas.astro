---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import PizzaCard from '../components/PizzaCard.astro';
import { pizzaTiers } from '../data/menu';
---

<Layout
  title="Nos pizzas — Molly Jefferson's Pizza Sannois"
  description="Découvrez toutes les pizzas artisanales de Molly Jefferson's Pizza à Sannois : des classiques aux recettes signature."
>
  <Hero
    size="compact"
    eyebrow="Pizza artisanale · Sannois"
    title="Nos pizzas"
    subtitle="Chaque pizza est garnie généreusement, sur une pâte travaillée sur place."
    image="/photos/hero-pizza.jpg"
    imageAlt="Pizza Molly Jefferson's Pizza garnie de pepperoni et olives noires"
  />

  <section class="bg-crust-950 py-20 sm:py-28">
    <div class="mx-auto max-w-7xl space-y-20 px-5 sm:px-8">
      {pizzaTiers.map((tier) => (
        <div>
          <h2 class="reveal font-display text-2xl font-bold text-cream-50 sm:text-3xl">{tier.title}</h2>
          <div class="mt-3 h-px w-16 bg-cheese-400"></div>
          <div class="mt-9 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
            {tier.pizzas.map((pizza, i) => <PizzaCard pizza={pizza} index={i} />)}
          </div>
        </div>
      ))}
    </div>
  </section>
</Layout>
