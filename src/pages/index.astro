---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Presentation from '../components/Presentation.astro';
import PromoBanner from '../components/PromoBanner.astro';
import PizzaShowcase from '../components/PizzaShowcase.astro';
import WhyUs from '../components/WhyUs.astro';
import Gallery from '../components/Gallery.astro';
import Reviews from '../components/Reviews.astro';
import LocationHours from '../components/LocationHours.astro';
import { restaurant } from '../data/restaurant';
---

<Layout
  title="Molly Jefferson's Pizza Sannois — Pizzeria artisanale, sur place & à emporter"
  description="Pizzeria artisanale à Sannois (95110) : pizzas généreuses, pâte au choix, plats végétariens. Sur place ou à emporter, 7j/7 sauf lundi midi."
>
  <Hero
    title="Molly Jefferson's Pizza"
    subtitle="Des pizzas généreuses préparées chaque jour à Sannois."
    image="/photos/hero-pizza.jpg"
    imageAlt="Part de pizza Molly Jefferson's Pizza tirée hors du four, fromage filant"
    primaryCta={{ label: 'Commander', href: restaurant.phoneHref }}
    secondaryCta={{ label: 'Voir le menu', href: '/menu' }}
  />

  <Presentation />

  <section class="bg-crust-900/60 py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-5 sm:px-8">
      <span class="reveal font-body text-xs font-semibold uppercase tracking-[0.3em] text-sauce-400">
        Offres à emporter
      </span>
      <div class="mt-6">
        <PromoBanner />
      </div>
    </div>
  </section>

  <PizzaShowcase />
  <WhyUs />

  <section class="bg-crust-900/60 py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-5 sm:px-8">
      <div class="flex flex-col items-center justify-between gap-6 sm:flex-row sm:items-end">
        <span class="reveal max-w-md text-center sm:text-left">
          <span class="font-body text-xs font-semibold uppercase tracking-[0.3em] text-sauce-400">En images</span>
          <h2 class="mt-3 font-display text-3xl font-bold text-cream-50 sm:text-4xl">Dans nos cuisines</h2>
        </span>
        <a
          href="/galerie"
          class="reveal shrink-0 rounded-full border border-cream-100/20 px-6 py-3 font-body text-sm font-semibold text-cream-50 transition-colors hover:border-cheese-400 hover:text-cheese-300"
        >
          Toute la galerie
        </a>
      </div>
      <div class="mt-12">
        <Gallery limit={4} />
      </div>
    </div>
  </section>

  <Reviews />
  <LocationHours />
</Layout>
